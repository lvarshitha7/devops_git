pipeline {
    agent any

    environment {
        IMAGE_NAME = "justice-app"
        CONTAINER_NAME = "justice-container"
        PORT = "3000"
    }

    stages {

        stage('Clone Code') {
            steps {
                git 'https://github.com/lvarshitha7/devops_git.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }
        stage('Build') {
            steps {
                sh 'npm install'
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build -t node-app .'
            }
        }

       
    }

    post {
        success {
            echo 'Deployment Successful!'
        }
        failure {
            echo 'Pipeline Failed!'
        }
    }
}